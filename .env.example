# Copie para .env e ajuste os valores.
# cp .env.example .env

# Obrigatório — Postgres (ex.: docker-compose na porta host 5433)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/iputa

# API
PORT=3000

# JWT (em produção use JWT_SECRET forte e único)
JWT_SECRET=dev-secret
JWT_EXPIRES_IN=7d

# Opcional — seed: promove este email a admin (usuário já deve existir)
# ADMIN_BOOTSTRAP_EMAIL=admin@example.com
